<Window x:Class="CookieClickerWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CookieClickerWpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <TextBlock Grid.Row="0" x:Name="CookiesText" Text="0 sušenek" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock x:Name="PerClickText" Text="Za kliknutí: 1" FontSize="14" HorizontalAlignment="Center"/>
            <TextBlock x:Name="PerSecondText" Text="Produkce: 0 / s" FontSize="14" HorizontalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="2" x:Name="CookieButton" Content="" FontSize="120" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CookieButton_Click"/>

    </Grid>
</Window>
