<Window x:Class="CookieClickerWpf.ShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obchod" Height="460" Width="820" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="CookiesInShopText" Text="Sušenky: 0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Lepší kurzor" FontWeight="Bold"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="+1 za kliknutí"/>
            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="PriceCursorText" Text="10" Margin="10,0"/>
            <Button Grid.Row="0" Grid.Column="3" x:Name="BuyCursorButton" Content="Koupit" Width="80" Click="BuyCursor_Click"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Dvojité kliknutí" FontWeight="Bold" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="+5 za kliknutí" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="PriceDoubleText" Text="50" Margin="10,8,10,0"/>
            <Button Grid.Row="1" Grid.Column="3" x:Name="BuyDoubleButton" Content="Koupit" Width="80" Margin="0,8,0,0" Click="BuyDouble_Click"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Babička pekařka" FontWeight="Bold" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="+1 / s" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="PriceGrandmaText" Text="100" Margin="10,8,10,0"/>
            <Button Grid.Row="2" Grid.Column="3" x:Name="BuyGrandmaButton" Content="Koupit" Width="80" Margin="0,8,0,0" Click="BuyGrandma_Click"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Malá pekárna" FontWeight="Bold" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="+5 / s" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="PriceBakeryText" Text="500" Margin="10,8,10,0"/>
            <Button Grid.Row="3" Grid.Column="3" x:Name="BuyBakeryButton" Content="Koupit" Width="80" Margin="0,8,0,0" Click="BuyBakery_Click"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Továrna na sušenky" FontWeight="Bold" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="+25 / s" Margin="0,8,0,0"/>
            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="PriceFactoryText" Text="2500" Margin="10,8,10,0"/>
            <Button Grid.Row="4" Grid.Column="3" x:Name="BuyFactoryButton" Content="Koupit" Width="80" Margin="0,8,0,0" Click="BuyFactory_Click"/>
        </Grid>
    </Grid>
</Window>